{
  "entities": {
    "MarketListing": {
      "title": "Market Listing",
      "description": "A product listed for sale in the marketplace.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "unit": { "type": "string" },
        "quantity": { "type": "number" },
        "availableQuantity": { "type": "number" },
        "soldQuantity": { "type": "number" },
        "location": { "type": "string" },
        "deliveryMethod": { "type": "string" },
        "description": { "type": "string" },
        "businessName": { "type": "string" },
        "phone": { "type": "string" },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerStatus": { "type": "string", "enum": ["basic", "verified", "premium"] },
        "verified": { "type": "boolean" },
        "imageUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "sold", "hidden"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "price", "unit", "quantity", "sellerId", "status", "createdAt"]
    },
    "MarketDemand": {
      "title": "Market Demand",
      "description": "A request from a user looking for a specific commodity.",
      "type": "object",
      "properties": {
        "commodity": { "type": "string" },
        "category": { "type": "string" },
        "quantity": { "type": "number" },
        "unit": { "type": "string" },
        "quantityFound": { "type": "number" },
        "priceRange": { "type": "string" },
        "location": { "type": "string" },
        "urgency": { "type": "string", "enum": ["normal", "urgent"] },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "requesterType": { "type": "string", "enum": ["individual", "farmer", "trader", "processor", "business"] },
        "phone": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "matched", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["commodity", "category", "quantity", "unit", "userId", "status", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile and settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "primaryRole": { "type": "string", "enum": ["seller", "business", "cooperative", "ngo"] },
        "roles": { "type": "array", "items": { "type": "string", "enum": ["seller", "business", "cooperative", "ngo"] } },
        "status": { "type": "string", "enum": ["basic", "verified", "premium"] },
        "sellerProfile": { "$ref": "SellerProfile" },
        "organizationProfile": { "$ref": "OrganizationProfile" },
        "verification": {
          "type": "object",
          "properties": {
            "status": { "type": "string", "enum": ["none", "pending", "verified", "rejected"] },
            "type": { "type": "string", "enum": ["seller", "business", "cooperative", "ngo"] },
            "submittedAt": { "type": "string", "format": "date-time" },
            "reviewedAt": { "type": "string", "format": "date-time" },
            "rejectionReason": { "type": "string" },
            "documents": {
              "type": "object",
              "properties": {
                "idDocument": { "type": "string" },
                "certificate": { "type": "string" },
                "license": { "type": "string" },
                "proofImage": { "type": "string" }
              }
            }
          }
        },
        "emailVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "roles", "status", "createdAt"]
    },
    "SellerProfile": {
      "title": "Seller Profile",
      "description": "Profile details for individual sellers.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["individual_seller"] },
        "businessName": { "type": "string" },
        "category": { "type": "string" },
        "district": { "type": "string" },
        "deliveryMethod": { "type": "string" },
        "verified": { "type": "boolean" }
      }
    },
    "OrganizationProfile": {
      "title": "Organization Profile",
      "description": "Profile details for businesses, cooperatives, or NGOs.",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["business", "cooperative", "ngo"] },
        "organizationName": { "type": "string" },
        "contactPerson": { "type": "string" },
        "district": { "type": "string" },
        "description": { "type": "string" },
        "verified": { "type": "boolean" }
      }
    },
    "HiddenListing": {
      "title": "Hidden Listing",
      "description": "A listing hidden by a user.",
      "type": "object",
      "properties": {
        "listingId": { "type": "string" },
        "sellerId": { "type": "string" },
        "hiddenAt": { "type": "string", "format": "date-time" }
      },
      "required": ["listingId", "hiddenAt"]
    },
    "SavedListing": {
      "title": "Saved Listing",
      "description": "A listing saved by a user.",
      "type": "object",
      "properties": {
        "listingId": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["listingId", "savedAt"]
    }
  },
  "firestore": {
    "market_listings": {
      "schema": "MarketListing",
      "description": "Collection of products for sale."
    },
    "market_demands": {
      "schema": "MarketDemand",
      "description": "Collection of market demands."
    },
    "users": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "users/{userId}/hidden_listings": {
      "schema": "HiddenListing",
      "description": "Subcollection of listings hidden by a specific user."
    },
    "users/{userId}/saved_listings": {
      "schema": "SavedListing",
      "description": "Subcollection of listings saved by a specific user."
    }
  }
}
